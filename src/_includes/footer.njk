<footer>
  <div class="wrap-wide">
    <span>A <a href="https://www.bitmoor.co.uk">Bitmoor</a> product. Founded by <a href="{{ site.author.url }}">{{ site.author.name }}</a>. MIT licensed.</span>
    <span class="footer-links">
      {% for item in nav.footer %}
        <a href="{{ item.href }}">{{ item.label }}</a>
        {% if not loop.last %}<span class="sep">·</span>{% endif %}
      {% endfor %}
    </span>
  </div>
</footer>

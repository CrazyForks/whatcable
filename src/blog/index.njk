---
layout: base.njk
permalink: /blog.html
title: "Blog"
documentTitle: "WhatCable Field Notes: USB-C, Thunderbolt & Mac Hardware"
description: "Practical guides, protocol deep dives, and findings from real USB-C and Thunderbolt hardware on the Mac."
feedUrl: /blog/feed.xml
feedTitle: WhatCable Field Notes
extraHead: |
  <style>
    .blog-index { background: var(--bg); }
    .blog-index h1, .blog-index h2, .blog-index h3, .blog-index p { margin-top: 0; }
    .blog-index .blog-hero {
      position: relative;
      overflow: hidden;
      padding: 86px 0 72px;
      border-bottom: 1px solid var(--line);
    }
    .blog-index .blog-hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(ellipse 50% 70% at 88% 12%, rgba(12, 140, 166, 0.12), transparent 68%),
        linear-gradient(180deg, rgba(255,255,255,0.6), transparent);
      pointer-events: none;
    }
    .blog-index .hero-inner { position: relative; max-width: 820px; }
    .blog-index .eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 18px;
      color: var(--accent);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
    }
    .blog-index .eyebrow::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--accent);
    }
    .blog-index .blog-hero h1 {
      max-width: 760px;
      margin-bottom: 20px;
      font-size: clamp(42px, 6vw, 68px);
      line-height: 1.02;
      letter-spacing: -0.035em;
    }
    .blog-index .blog-hero .lede {
      max-width: 680px;
      margin-bottom: 28px;
      color: var(--ink-soft);
      font-size: clamp(18px, 2vw, 21px);
      line-height: 1.55;
    }
    .blog-index .hero-links { display: flex; flex-wrap: wrap; gap: 18px; font-size: 14px; font-weight: 600; }

    .blog-index .featured-section { padding: 72px 0 40px; }
    .blog-index .section-label {
      display: block;
      margin-bottom: 18px;
      color: var(--muted);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }
    .blog-index .featured-card {
      display: grid;
      grid-template-columns: minmax(0, 1.15fr) minmax(320px, 0.85fr);
      min-height: 430px;
      overflow: hidden;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: var(--panel);
      box-shadow: var(--shadow-md);
    }
    .blog-index .featured-media { min-height: 360px; background: var(--line-soft); }
    .blog-index .featured-media img { width: 100%; height: 100%; object-fit: cover; display: block; }
    .blog-index .featured-copy { display: flex; flex-direction: column; justify-content: center; padding: 46px; }
    .blog-index .post-meta { margin-bottom: 16px; color: var(--muted); font-size: 13px; }
    .blog-index .post-meta .category { color: var(--accent); font-weight: 700; }
    .blog-index .featured-copy h2 { margin-bottom: 16px; font-size: clamp(28px, 3vw, 40px); line-height: 1.08; letter-spacing: -0.02em; }
    .blog-index .featured-copy h2 a, .blog-index .article-card h3 a { color: var(--ink); text-decoration: none; }
    .blog-index .featured-copy h2 a:hover, .blog-index .article-card h3 a:hover { color: var(--accent); }
    .blog-index .featured-copy .summary { margin-bottom: 24px; color: var(--ink-soft); font-size: 16px; line-height: 1.65; }
    .blog-index .read-link { font-size: 14px; font-weight: 700; }

    .blog-index .topics-section { padding: 32px 0 72px; }
    .blog-index .topics-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .blog-index .topic-card {
      padding: 24px;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--panel);
      color: var(--ink);
      text-decoration: none;
      transition: transform 0.15s ease, border-color 0.15s ease;
    }
    .blog-index .topic-card:hover { transform: translateY(-2px); border-color: #c8d0db; }
    .blog-index .topic-icon {
      display: grid;
      place-items: center;
      width: 38px;
      height: 38px;
      margin-bottom: 18px;
      border-radius: 10px;
      background: var(--accent-soft);
      color: var(--accent);
    }
    .blog-index .topic-card strong { display: block; margin-bottom: 6px; font-size: 16px; }
    .blog-index .topic-card span { color: var(--ink-soft); font-size: 14px; line-height: 1.5; }

    .blog-index .latest-section { padding: 72px 0; border-top: 1px solid var(--line); background: var(--panel); }
    .blog-index .section-heading { margin-bottom: 32px; font-size: clamp(28px, 3vw, 38px); letter-spacing: -0.02em; }
    .blog-index .article-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    .blog-index .article-card { overflow: hidden; border: 1px solid var(--line); border-radius: 14px; background: var(--bg); }
    .blog-index .article-card img { display: block; width: 100%; aspect-ratio: 16 / 9; object-fit: cover; }
    .blog-index .article-copy { padding: 28px; }
    .blog-index .article-card h3 { margin-bottom: 12px; font-size: 23px; line-height: 1.2; letter-spacing: -0.01em; }
    .blog-index .article-card .summary { margin-bottom: 0; color: var(--ink-soft); font-size: 15px; line-height: 1.6; }

    .blog-index .archive { padding: 56px 0 72px; background: var(--panel); }
    .blog-index .archive-list { border-top: 1px solid var(--line); }
    .blog-index .archive-row {
      display: grid;
      grid-template-columns: 130px 1fr auto;
      gap: 24px;
      align-items: center;
      padding: 22px 0;
      border-bottom: 1px solid var(--line);
    }
    .blog-index .archive-row time, .blog-index .archive-row .archive-category { color: var(--muted); font-size: 13px; }
    .blog-index .archive-row a { color: var(--ink); font-weight: 650; text-decoration: none; }
    .blog-index .archive-row a:hover { color: var(--accent); }

    .blog-index .blog-cta { padding: 72px 0; background: var(--ink); color: #fff; }
    .blog-index .cta-inner { display: flex; justify-content: space-between; gap: 48px; align-items: center; }
    .blog-index .blog-cta h2 { margin-bottom: 10px; color: #fff; font-size: clamp(28px, 3vw, 38px); }
    .blog-index .blog-cta p { max-width: 600px; margin-bottom: 0; color: rgba(255,255,255,0.68); font-size: 17px; }
    .blog-index .cta-actions { display: flex; flex-wrap: wrap; gap: 12px; flex-shrink: 0; }
    .blog-index .cta-button { display: inline-flex; align-items: center; min-height: 48px; padding: 12px 20px; border-radius: 9px; font-weight: 700; text-decoration: none; }
    .blog-index .cta-button.primary { background: var(--accent); color: #fff; }
    .blog-index .cta-button.secondary { border: 1px solid rgba(255,255,255,0.28); color: #fff; }

    @media (max-width: 820px) {
      .blog-index .featured-card { grid-template-columns: 1fr; }
      .blog-index .featured-media { min-height: 280px; }
      .blog-index .topics-grid { grid-template-columns: 1fr; }
      .blog-index .cta-inner { align-items: flex-start; flex-direction: column; }
    }
    @media (max-width: 620px) {
      .blog-index .blog-hero { padding: 64px 0 54px; }
      .blog-index .blog-hero h1 { font-size: 38px; }
      .blog-index .featured-section, .blog-index .latest-section { padding-top: 52px; }
      .blog-index .featured-copy { padding: 28px 24px; }
      .blog-index .article-grid { grid-template-columns: 1fr; }
      .blog-index .archive-row { grid-template-columns: 1fr; gap: 7px; }
      .blog-index .archive-row .archive-category { display: none; }
      .blog-index .cta-actions, .blog-index .cta-button { width: 100%; }
      .blog-index .cta-button { justify-content: center; }
    }
  </style>
---
<main class="blog-index">
  <header class="blog-hero">
    <div class="wrap-wide hero-inner">
      <span class="eyebrow">WhatCable Field Notes</span>
      <h1>What the connector doesn't tell you.</h1>
      <p class="lede">Practical guides, protocol deep dives and findings from real Apple hardware. We explain what negotiated, what limited the connection and how to prove it.</p>
      <div class="hero-links">
        <a href="#latest">Read the latest</a>
        <a href="/blog/feed.xml">Subscribe via RSS</a>
      </div>
    </div>
  </header>

  {% if collections.posts and collections.posts.length %}
    {% set featured = collections.posts[0] %}
    <section class="featured-section">
      <div class="wrap-wide">
        <span class="section-label">Featured investigation</span>
        <article class="featured-card">
          <a class="featured-media" href="{{ featured.url | cleanUrl }}" aria-label="Read {{ featured.data.title }}">
            <img src="{{ featured.data.coverImage }}" alt="{{ featured.data.coverAlt }}">
          </a>
          <div class="featured-copy">
            <p class="post-meta"><span class="category">{{ featured.data.category }}</span> &nbsp;·&nbsp; <time datetime="{{ featured.date | isoDate }}">{{ featured.date | readableDate }}</time></p>
            <h2><a href="{{ featured.url | cleanUrl }}">{{ featured.data.title }}</a></h2>
            <p class="summary">{{ featured.data.summary }}</p>
            <a class="read-link" href="{{ featured.url | cleanUrl }}">Read the investigation →</a>
          </div>
        </article>
      </div>
    </section>

    <section class="topics-section" aria-labelledby="topics-heading">
      <div class="wrap-wide">
        <span class="section-label" id="topics-heading">Start with a question</span>
        <div class="topics-grid">
          <a class="topic-card" href="/blog/tag/charging">
            <span class="topic-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L4 14h7l-1 8 9-12h-7l1-8z"/></svg></span>
            <strong>Why is charging slow?</strong>
            <span>Follow the power contract through the charger, cable and Mac.</span>
          </a>
          <a class="topic-card" href="/blog/tag/diagnostics">
            <span class="topic-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg></span>
            <strong>What is limiting the link?</strong>
            <span>Separate the cable's capability from what the connection delivered.</span>
          </a>
          <a class="topic-card" href="/blog/tag/thunderbolt">
            <span class="topic-icon" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L6 12h5l-1 10 8-13h-5V2z"/></svg></span>
            <strong>USB-C or Thunderbolt?</strong>
            <span>Understand the protocols that share one deceptively simple connector.</span>
          </a>
        </div>
      </div>
    </section>

    <section class="latest-section" id="latest">
      <div class="wrap-wide">
        <span class="section-label">Latest field notes</span>
        <h2 class="section-heading">Guides and deep dives</h2>
        <div class="article-grid">
          {% for post in collections.posts %}
            {% if loop.index0 > 0 and loop.index0 < 3 %}
              <article class="article-card">
                <a href="{{ post.url | cleanUrl }}" aria-label="Read {{ post.data.title }}">
                  <img src="{{ post.data.coverImage }}" alt="{{ post.data.coverAlt }}" loading="lazy">
                </a>
                <div class="article-copy">
                  <p class="post-meta"><span class="category">{{ post.data.category }}</span> &nbsp;·&nbsp; <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time></p>
                  <h3><a href="{{ post.url | cleanUrl }}">{{ post.data.title }}</a></h3>
                  <p class="summary">{{ post.data.summary }}</p>
                </div>
              </article>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </section>

    <section class="archive">
      <div class="wrap-wide">
        <span class="section-label">From the archive</span>
        <div class="archive-list">
          {% for post in collections.posts %}
            {% if loop.index0 >= 3 %}
              <div class="archive-row">
                <time datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
                <a href="{{ post.url | cleanUrl }}">{{ post.data.title }}</a>
                <span class="archive-category">{{ post.data.category }}</span>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </section>
  {% endif %}

  <section class="blog-cta">
    <div class="wrap-wide cta-inner">
      <div>
        <h2>See what your own connection is doing.</h2>
        <p>WhatCable reads the port, cable, charger and connected device, then explains the result in plain English.</p>
      </div>
      <div class="cta-actions">
        <a class="cta-button primary" href="/">Download WhatCable</a>
        <a class="cta-button secondary" href="/pro">Explore Pro</a>
      </div>
    </div>
  </section>
</main>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "WhatCable Field Notes",
  "description": {{ description | dump | safe }},
  "url": "{{ site.url }}/blog",
  "publisher": {
    "@type": "Organization",
    "name": {{ site.name | dump | safe }},
    "url": {{ site.url | dump | safe }},
    "logo": { "@type": "ImageObject", "url": "{{ site.url }}/icon.png" }
  },
  "blogPost": [
{%- for post in collections.posts %}
    {
      "@type": "BlogPosting",
      "headline": {{ post.data.title | dump | safe }},
      "description": {{ (post.data.summary or "") | dump | safe }},
      "url": "{{ site.url }}{{ post.url | cleanUrl }}",
      "datePublished": {{ post.date | isoDate | dump | safe }}
    }{% if not loop.last %},{% endif %}
{%- endfor %}
  ]
}
</script>
